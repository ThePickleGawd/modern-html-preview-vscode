{
  "name": "vscode-browser-ssh",
  "displayName": "Browser SSH Preview",
  "description": "Preview workspace HTML files and remote-rendered HTTP/HTTPS URLs inside VS Code.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vscode-browser-ssh.openHtml",
    "onCommand:vscode-browser-ssh.openUrl",
    "onCommand:vscode-browser-ssh.openUrlAtCursor"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vscode-browser-ssh.openHtml",
        "title": "Open HTML in VS Code Browser",
        "category": "Browser SSH"
      },
      {
        "command": "vscode-browser-ssh.openUrl",
        "title": "Open URL in Remote Browser",
        "category": "Browser SSH"
      },
      {
        "command": "vscode-browser-ssh.openUrlAtCursor",
        "title": "Open URL at Cursor in Remote Browser",
        "category": "Browser SSH"
      }
    ],
    "keybindings": [
      {
        "command": "vscode-browser-ssh.openHtml",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorTextFocus && (resourceExtname == .html || resourceExtname == .htm)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "vscode-browser-ssh.openHtml",
          "when": "resourceExtname == .html || resourceExtname == .htm",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "vscode-browser-ssh.openHtml",
          "when": "resourceExtname == .html || resourceExtname == .htm",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "vscode-browser-ssh.openUrlAtCursor",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc --noEmit -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "playwright-core": "^1.60.0",
    "typescript": "^5.7.2"
  }
}
